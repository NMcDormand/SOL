menu "menu"
	elem 
		name = "File"
		command = ""
		saved-params = "is-checked"
	elem 
		name = "&Save"
		command = "Save"
		category = "File"
		saved-params = "is-checked"
	elem 
		name = "Save and &Logout"
		command = "LeaveGame"
		category = "File"
		saved-params = "is-checked"
	elem 
		name = "Save and &Quit"
		command = ".quit"
		category = "File"
		saved-params = "is-checked"
	elem 
		name = "&Options and Messages..."
		command = ".options"
		category = "File"
		saved-params = "is-checked"
	elem 
		name = "&Save screenshot..."
		command = ".screenshot"
		category = "File"
		saved-params = "is-checked"
	elem "Options"
		name = "Options"
		command = ""
		saved-params = "is-checked"
	elem "icon32"
		name = "&32x32"
		command = ".winset \"mainwindow.map.icon-size=32\""
		category = "Options"
		can-check = true
		group = "size"
		saved-params = "is-checked"
	elem "icon16"
		name = "&16x16"
		command = ".winset \"mappane.map.icon-size=16\""
		category = "Options"
		can-check = true
		group = "size"
		saved-params = "is-checked"
	elem "stretch"
		name = "&Stretch to fit"
		command = ".winset \"mainwindow.map.icon-size=0\""
		category = "Options"
		can-check = true
		group = "size"
		saved-params = "is-checked"
	elem 
		name = ""
		command = ""
		category = "Options"
		saved-params = "is-checked"
	elem "textmode"
		name = "&Text"
		command = ".winset \"menu.textmode.is-checked=true?mappane.map.text-mode=true:mappane.map.text-mode=false\""
		category = "Options"
		can-check = true
		saved-params = "is-checked"


