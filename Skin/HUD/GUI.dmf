macro "Creation"
	elem 
		name = "RETURN"
		command = "Create-Final"
	elem 
		name = "ESCAPE"
		command = "BackToStart"

macro "Login"
	elem 
		name = "Escape"
		command = "QuitGame"
	elem 
		name = "Space"
		command = "StartGame"
