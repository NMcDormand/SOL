macro "Game"
	elem 
		name = "Center"
		command = "MoveMac \"center\" 1"
	elem 
		name = "Center+UP"
		command = "MoveMac \"center\" 1"
	elem 
		name = "ALT+Return"
		command = ".output browser1:ToggleFullscreen null"
	elem 
		name = "Northeast"
		command = "MoveMac \"northeast\" 1"
	elem 
		name = "Northeast+UP"
		command = "MoveMac \"northeast\" 0"
	elem 
		name = "Southeast"
		command = "MoveMac \"southeast\" 1"
	elem 
		name = "Southeast+UP"
		command = "MoveMac \"southeast\" 0"
	elem 
		name = "Southwest"
		command = "MoveMac \"southwest\" 1"
	elem 
		name = "Southwest+UP"
		command = "MoveMac \"southwest\" 0"
	elem 
		name = "Northwest"
		command = "MoveMac \"northwest\" 1"
	elem 
		name = "Northwest+UP"
		command = "MoveMac \"northwest\" 0"
	elem 
		name = "West"
		command = "MoveMac \"west\" 1"
	elem 
		name = "West+UP"
		command = "MoveMac \"west\" 0"
	elem 
		name = "North"
		command = "MoveMac \"north\" 1"
	elem 
		name = "North+UP"
		command = "MoveMac \"north\" 0"
	elem 
		name = "East"
		command = "MoveMac \"east\" 1"
	elem 
		name = "East+UP"
		command = "MoveMac \"east\" 0"
	elem 
		name = "South"
		command = "MoveMac \"south\" 1"
	elem 
		name = "South+UP"
		command = "MoveMac \"south\" 0"

