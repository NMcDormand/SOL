window "AdminWindow"
	elem "AdminWindow"
		type = MAIN
		pos = 281,0
		size = 400x300
		anchor1 = -1,-1
		anchor2 = -1,-1
		background-color = #000000
		is-visible = false
		saved-params = "pos;size;is-minimized;is-maximized"
		title = "Admin Commands"
		statusbar = false
		icon = 'Images\\3232.png'
	elem "info1"
		type = INFO
		pos = 0,0
		size = 400x300
		anchor1 = 0,0
		anchor2 = 100,100
		font-family = "Arial,Verdana"
		font-size = 7
		text-color = #950000
		background-color = #000000
		saved-params = ""
		highlight-color = #fd0000
		tab-text-color = #e8e8e8
		tab-background-color = #0a0c0e
		tab-font-family = "Arial,Verdana"
		tab-font-size = 7

